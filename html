        // =========================================================
        // 10. CORE GAME LOOP, CAMERA, & PHYSICS
        // =========================================================
        const keys = {}; 
        window.addEventListener('keydown', e => { 
            if (e.code === 'Enter' && window.gameActive) {
                const input = document.getElementById('ig-chat-input');
                const container = document.getElementById('ig-chat-input-container');
                if (document.activeElement === input) {
                    window.isTyping = false; if(container) container.style.display = 'none'; if(input){ input.blur(); sendChatFromInput('ig-chat-input'); }
                } else {
                    window.isTyping = true; if(container) container.style.display = 'flex'; if(input) input.focus(); e.preventDefault();
                }
            }
            if (window.isTyping) return; 
            keys[e.code] = true; 
            if ((e.code === 'KeyE' || e.code === 'ShiftLeft') && window.gameActive) useItem();
        });
        window.addEventListener('keyup', e => keys[e.code] = false);

        var isDraggingCam = false;
        document.addEventListener('mousedown', (e) => { 
            if(e.target.closest('#ui-container') || e.target.closest('#lobby')) return;
            isDraggingCam = true; const hint = document.getElementById('look-hint'); if(hint) hint.style.opacity = '0'; 
        });
        document.addEventListener('mouseup', () => isDraggingCam = false);
        document.addEventListener('mousemove', (e) => {
            if(isDraggingCam && window.gameActive && !isFrozen) {
                camYaw -= e.movementX * 0.005; camPitch -= e.movementY * 0.005;
                camPitch = Math.max(-Math.PI/2 + 0.1, Math.min(Math.PI/2 - 0.1, camPitch));
            }
