        var lastHandledEventTs = {};
        var roomCmdTs = 0;
        var pendingEvent = null;

        function syncEvent(eventType, payload={}) { pendingEvent = { type: eventType, ts: Date.now(), ...payload }; syncLocalPlayer(true); }

        function setupMultiplayerListeners() {
            if (!db) return;
            const roomRef = doc(db, 'artifacts', appId, 'public', 'data', 'rooms', roomCode);
            onSnapshot(roomRef, (snap) => {
                if (!snap.exists()) return;
                const data = snap.data();
                if (data.ts > roomCmdTs) {
                    roomCmdTs = data.ts;
                    if (data.cmd === 'start') {
                        raceStarted = true; raceFinished = false; startTime = data.startTime;
                        if(!window.gameActive) enterGame();
                        if (startBarrier) { scene.remove(startBarrier); startBarrier = null; }
                        showFloatingText("GO!", playerGrp.position, "#d946ef");
                    } else if (data.cmd === 'reset') {
                        raceStarted = false; raceFinished = false; document.getElementById('timer').innerText = "WAITING";
                        currentStage = 1; respawnPoint.set(0, 10, 0); dieAndRespawn("ADMIN RESET");
                        leaderboard = []; updateLeaderboardUI(); document.getElementById('race-message').style.display = 'none';
                        if (!startBarrier) { startBarrier = new THREE.Mesh(new THREE.PlaneGeometry(40, 30), MATS.barrier); startBarrier.position.set(0, 15, -20); scene.add(startBarrier); }
                    }
                }
            });

            const playersRef = collection(db, 'artifacts', appId, 'public', 'data', 'players');
            onSnapshot(playersRef, (snap) => {
                const now = Date.now();
                snap.forEach(docSnap => {
                    const data = docSnap.data();
                    if (data.room !== roomCode || now - data.timestamp > 10000 || docSnap.id === myId) return;

                    if (!remotePlayers.has(docSnap.id) || remotePlayers.get(docSnap.id).color !== data.color || remotePlayers.get(docSnap.id).type !== data.avatarType || remotePlayers.get(docSnap.id).accId !== data.accId) {
                        if (remotePlayers.has(docSnap.id)) scene.remove(remotePlayers.get(docSnap.id).model.group);
                        const newAv = createAvatar(data.color, data.avatarType, data.name, data.accId); scene.add(newAv.group);
                        remotePlayers.set(docSnap.id, { model: newAv, color: data.color, type: data.avatarType, name: data.name, accId: data.accId, tPos: new THREE.Vector3(), tRot: new THREE.Quaternion() });
                        updatePlayersUI();
                    }
                    const p = remotePlayers.get(docSnap.id);
                    p.tPos.set(data.x, data.y, data.z); p.tRot.set(data.qx, data.qy, data.qz, data.qw);
                    p.state = data.state; p.item = data.item; p.hasBoost = data.hasBoost; p.isFrozen = data.isFrozen; p.progressZ = data.z; p.lastSeen = now;

                    if (data.lastEvent && data.lastEvent.ts > (lastHandledEventTs[docSnap.id] || 0)) {
                        lastHandledEventTs[docSnap.id] = data.lastEvent.ts; const ev = data.lastEvent;
                        if (ev.type === 'chat') { appendChat(data.name, ev.text, "#"+data.color.toString(16).padStart(6,'0')); showFloatingText("💬", p.tPos, "#fff"); }
                        else if (ev.type === 'spawn_mine') spawnMine(docSnap.id, new THREE.Vector3(ev.x, ev.y, ev.z));
                        else if (ev.type === 'spawn_projectile') spawnProjectile(docSnap.id, new THREE.Vector3(ev.x, ev.y, ev.z), new THREE.Vector3(ev.dx, 0, ev.dz));
                        else if (ev.type === 'hit_mine' || ev.type === 'hit_projectile') {
                            const idx = dynamicObjects.findIndex(o => o.owner === ev.ownerId && o.type === (ev.type==='hit_mine'?'mine':'projectile') && o.active);
                            if(idx !== -1) { scene.remove(dynamicObjects[idx].mesh); dynamicObjects[idx].active = false; }
                        }
                        else if (ev.type === 'finish') updateLeaderboard(docSnap.id, data.name, ev.time);
                    }
                });

                remotePlayers.forEach((p, id) => {
                    if (now - p.lastSeen > 10000) {
                        scene.remove(p.model.group); remotePlayers.delete(id); updatePlayersUI();
                    }
                });
            }, (err) => console.warn(err));
        }

        var lastSyncTime = 0;
        function syncLocalPlayer(force = false) {
            if (!db || !myId || !window.gameActive || !playerGrp) return;
            const now = Date.now();
            if (!force && now - lastSyncTime < 80) return; lastSyncTime = now;

            let state = 'idle';
            if (isFrozen) state = 'frozen'; else if (isStunned) state = 'stun'; else if (!isGrounded) state = 'jump'; else if (Math.abs(velocity.x) > 0.05 || Math.abs(velocity.z) > 0.05) state = 'walk';

            const payload = {
                room: roomCode, name: myName, color: myAvatarColor, avatarType: myAvatarClass, accId: myAccessoryId,
                x: playerGrp.position.x, y: playerGrp.position.y, z: playerGrp.position.z,
                qx: playerGrp.quaternion.x, qy: playerGrp.quaternion.y, qz: playerGrp.quaternion.z, qw: playerGrp.quaternion.w,
                state: state, item: currentItem, hasBoost, isFrozen, timestamp: now
            };
            if (pendingEvent) { payload.lastEvent = pendingEvent; pendingEvent = null; }

            setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'players', myId), payload).catch(e => {});
        }

