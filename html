<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cyber Obby: Multiplayer!</title>
    <style>
        /* =========================================================
           UI & CSS STYLES
        ========================================================= */
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');
        
        body { margin: 0; overflow: hidden; background-color: #030308; font-family: 'Orbitron', sans-serif; user-select: none; color: white; }
        
        /* 3D Background Container */
        #bg-canvas-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; cursor: grab; }
        #bg-canvas-container:active { cursor: grabbing; }

        /* Lobby */
        #lobby { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at center, rgba(30,27,75,0.7) 0%, rgba(3,3,8,0.9) 100%); display: flex; flex-direction: row; align-items: center; justify-content: center; z-index: 100; gap: 40px; }
        
        #lobby-box { background: rgba(10, 10, 20, 0.85); padding: 30px; border-radius: 20px; backdrop-filter: blur(20px); border: 2px solid #00f2fe; text-align: center; box-shadow: 0 0 40px rgba(0, 242, 254, 0.3); width: 480px; flex-shrink: 0; max-height: 90vh; overflow-y: auto; }
        #chat-lobby-box { background: rgba(10, 10, 20, 0.85); padding: 20px; border-radius: 20px; backdrop-filter: blur(20px); border: 2px solid #8b5cf6; display: flex; flex-direction: column; width: 350px; height: 500px; box-shadow: 0 0 40px rgba(139, 92, 246, 0.3); display: none; }
        
        h1 { margin: 0 0 5px 0; font-size: 2.5rem; color: #00f2fe; text-shadow: 0 0 15px #00f2fe; text-transform: uppercase; letter-spacing: 2px; }
        .subtitle { font-size: 1rem; color: #94a3b8; margin-bottom: 20px; letter-spacing: 1px; }
        
        /* Scrollbar for lobby */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background: #00f2fe; border-radius: 4px; }
        
        /* Buttons & Inputs */
        .btn { padding: 14px 24px; font-size: 16px; font-weight: 800; border: none; border-radius: 12px; background: linear-gradient(90deg, #00f2fe, #4facfe); color: #030308; cursor: pointer; transition: all 0.2s; text-shadow: 0 1px 2px rgba(255,255,255,0.5); width: 100%; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 2px; font-family: 'Orbitron', sans-serif; }
        .btn:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(0, 242, 254, 0.5); }
        .btn:active { transform: translateY(1px); }
        .btn.secondary { background: rgba(255,255,255,0.05); border: 2px solid #00f2fe; color: #00f2fe; box-shadow: none; text-shadow: none; }
        .btn.secondary:hover { background: rgba(0, 242, 254, 0.2); }
        
        input[type="text"] { width: 100%; padding: 14px; font-size: 16px; border: 2px solid #00f2fe; border-radius: 12px; box-sizing: border-box; margin-bottom: 15px; text-align: center; background: rgba(0,0,0,0.5); color: #fff; text-transform: uppercase; font-weight: bold; letter-spacing: 2px; font-family: 'Orbitron', sans-serif; outline: none; }
        input[type="text"]:focus { border-color: #d946ef; box-shadow: 0 0 15px rgba(217,70,239,0.5); }

        /* Avatar Customization */
        .color-title { color: #00f2fe; font-weight: 800; margin-bottom: 10px; font-size: 12px; letter-spacing: 2px; text-align: left; border-bottom: 1px solid rgba(0,242,254,0.3); padding-bottom: 5px; }
        
        .color-swatches { display: flex; justify-content: flex-start; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
        .swatch { width: 30px; height: 30px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; }
        .swatch:hover { transform: scale(1.1); }
        .swatch.selected { border: 2px solid #fff; box-shadow: 0 0 15px currentColor; transform: scale(1.2); }
        
        .class-selector { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
        .class-btn { background: rgba(0,0,0,0.5); border: 2px solid #334155; color: #94a3b8; padding: 8px; border-radius: 8px; cursor: pointer; font-family: 'Orbitron', sans-serif; font-size: 11px; font-weight: bold; transition: 0.2s; }
        .class-btn:hover { border-color: #00f2fe; color: #00f2fe; }
        .class-btn.selected { border-color: #d946ef; color: #d946ef; background: rgba(217,70,239,0.1); box-shadow: 0 0 10px rgba(217,70,239,0.3); }

        /* Accessory Grid */
        .acc-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-bottom: 25px; max-height: 150px; overflow-y: auto; padding-right: 5px; }
        .acc-btn { background: rgba(0,0,0,0.5); border: 1px solid #334155; border-radius: 8px; padding: 8px 0; font-size: 18px; cursor: pointer; transition: 0.2s; }
        .acc-btn:hover { border-color: #00f2fe; transform: scale(1.05); }
        .acc-btn.selected { background: rgba(0,242,254,0.2); border-color: #00f2fe; box-shadow: 0 0 10px rgba(0,242,254,0.4); }

        /* Lobby Menus */
        #host-menu, #loading-menu, #preview-box { display: none; }
        .room-code-display { font-size: 3.5rem; font-weight: 900; color: #d946ef; letter-spacing: 8px; margin: 5px 0; text-shadow: 0 0 25px rgba(217,70,239,0.8); }
        .link-box { font-size: 12px; padding: 10px; background: rgba(0,0,0,0.6); border-radius: 8px; margin-bottom: 15px; color: #cbd5e1; word-break: break-all; border: 1px solid #334155; }
        
        /* Chat System */
        .chat-container { flex-grow: 1; overflow-y: auto; background: rgba(0,0,0,0.5); border-radius: 12px; padding: 10px; margin-bottom: 15px; border: 1px solid #334155; display: flex; flex-direction: column; gap: 8px; text-align: left; }
        .chat-msg { font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 14px; line-height: 1.4; text-shadow: 1px 1px 1px #000; }
        .chat-name { font-weight: bold; color: #00f2fe; margin-right: 5px; }
        .chat-input-row { display: flex; gap: 10px; }
        .chat-input-row input { margin-bottom: 0; font-size: 14px; text-transform: none; text-align: left; }
        
        /* HUD UI */
        #ui-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; display: none; z-index: 10; }
        .hud-panel { background: rgba(3, 3, 8, 0.7); border: 2px solid #00f2fe; border-radius: 16px; padding: 15px; pointer-events: auto; box-shadow: 0 0 20px rgba(0,242,254,0.2); backdrop-filter: blur(8px); }
        
        #room-code-hud { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); background: rgba(3, 3, 8, 0.8); border: 2px solid #d946ef; padding: 10px 30px; border-radius: 12px; text-align: center; box-shadow: 0 0 20px rgba(217,70,239,0.3); pointer-events: auto; display: flex; flex-direction: column; gap: 5px; z-index: 20; }
        #room-code-hud span { font-size: 12px; color: #94a3b8; font-weight: bold; letter-spacing: 1px; }
        #hud-code-display { font-size: 24px; font-weight: 900; color: #d946ef; letter-spacing: 5px; text-shadow: 0 0 10px rgba(217,70,239,0.8); }

        #top-left-hud { position: absolute; top: 20px; left: 20px; min-width: 220px; }
        #time-board { font-size: 32px; font-weight: 900; color: #fff; text-shadow: 0 0 10px #00f2fe; }
        #stage-indicator { font-size: 16px; color: #d946ef; font-weight: 800; letter-spacing: 2px; margin-bottom: 5px; }
        #status-board { font-size: 14px; color: #94a3b8; margin-top: 5px; }
        
        /* Sprint Bar */
        #sprint-container { width: 100%; height: 18px; background: rgba(0,0,0,0.8); border: 2px solid #3b82f6; border-radius: 8px; margin-top: 10px; overflow: hidden; position: relative; }
        #sprint-fill { width: 100%; height: 100%; background: linear-gradient(90deg, #1d4ed8 0%, #60a5fa 100%); transition: width 0.1s linear; }
        #sprint-text { position: absolute; top: 0; left: 0; width: 100%; height: 100%; text-align: center; font-size: 11px; line-height: 18px; font-weight: bold; text-shadow: 1px 1px 1px #000; letter-spacing: 1px; color: #fff; }

        /* In-Game Chat */
        #in-game-chat { position: absolute; bottom: 20px; left: 20px; width: 350px; display: flex; flex-direction: column; pointer-events: auto; }
        #ig-chat-messages { height: 150px; overflow-y: auto; background: transparent; display: flex; flex-direction: column; justify-content: flex-end; gap: 4px; margin-bottom: 10px; pointer-events: none; }
        #ig-chat-input-container { display: none; } /* Hidden until Enter is pressed */

        /* Mario Kart Item Box */
        #item-slot-container { position: absolute; bottom: 30px; right: 30px; display: flex; align-items: flex-end; gap: 15px; }
        #item-slot { width: 90px; height: 90px; border: 3px solid #00f2fe; border-radius: 16px; background: rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; font-size: 45px; box-shadow: 0 0 25px rgba(0,242,254,0.4); transition: transform 0.2s; }
        .item-key-hint { font-size: 18px; font-weight: bold; background: #fff; color: #000; padding: 5px 12px; border-radius: 8px; margin-bottom: 10px; }

        /* Progress & Controls */
        #top-right-hud { position: absolute; top: 20px; right: 20px; text-align: right; width: 260px; }
        .key { display: inline-block; background: #00f2fe; color: #000; padding: 2px 6px; border-radius: 6px; font-weight: bold; margin: 0 2px; font-size: 12px; }
        
        #leaderboard-hud { margin-top: 15px; text-align: left; }
        .lb-title { color: #d946ef; font-weight: 800; font-size: 14px; border-bottom: 2px solid #4c1d95; padding-bottom: 5px; margin-bottom: 10px; }
        .leaderboard-entry { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid rgba(0,242,254,0.2); font-size: 14px; }
        
        /* Host Admin Panel */
        #host-panel { position: absolute; top: 250px; left: 20px; width: 240px; border-color: #ef4444; box-shadow: 0 0 20px rgba(239,68,68,0.3); display: none; }
        
        /* Screen Messages */
        #race-message { position: absolute; top: 30%; left: 50%; transform: translateX(-50%); font-size: 5rem; font-weight: 900; color: #fff; text-shadow: 0 0 30px #d946ef, 0 0 10px #d946ef; display: none; text-align: center; z-index: 50; font-style: italic; letter-spacing: 5px; }
        .floating-text { position: absolute; font-weight: 900; font-size: 24px; pointer-events: none; text-shadow: 2px 2px 0 #000, 0 0 10px currentColor; animation: floatUp 1.2s forwards; z-index: 10; font-family: 'Orbitron', sans-serif; }
        @keyframes floatUp { 0% { opacity: 1; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(-80px) scale(1.5); } }

        /* Effects */
        #freeze-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(100, 200, 255, 0.4); border: 20px solid rgba(255,255,255,0.5); box-sizing: border-box; pointer-events: none; display: none; z-index: 40; backdrop-filter: blur(4px); }
        #speed-lines { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; opacity: 0; background: radial-gradient(circle, transparent 50%, rgba(255,255,255,0.2) 100%); transition: opacity 0.2s; z-index: 30;}
        #look-hint { position: absolute; bottom: 120px; left: 50%; transform: translateX(-50%); font-size: 18px; color: #fff; text-shadow: 0 0 10px #00f2fe; background: rgba(0,0,0,0.5); padding: 10px 20px; border-radius: 20px; border: 1px solid #00f2fe; pointer-events: none; opacity: 0.8; transition: opacity 0.5s; }
    </style>
</head>
<body>
    <div id="bg-canvas-container"></div>

    <!-- LOBBY SCREEN -->
    <div id="lobby">
        <div id="lobby-box">
            <h1>CYBER OBBY</h1>
            <p class="subtitle">Multiplayer Platformer Racing</p>
            
            <div id="setup-menu">
                <input type="text" id="player-name" placeholder="ENTER USERNAME" maxlength="12" value="RACER">
                
                <p class="color-title">CHASSIS TYPE</p>
                <div class="class-selector">
                    <div class="class-btn selected" data-class="classic">CLASSIC</div>
                    <div class="class-btn" data-class="heavy">HEAVY BRUTE</div>
                    <div class="class-btn" data-class="sleek">SLEEK NINJA</div>
                    <div class="class-btn" data-class="hover">HOVER DRONE</div>
                </div>

                <p class="color-title">ARMOR PAINT</p>
                <div class="color-swatches" id="swatch-container">
                    <div class="swatch selected" style="background: #3b82f6; color: #3b82f6;" data-hex="0x3b82f6"></div>
                    <div class="swatch" style="background: #ef4444; color: #ef4444;" data-hex="0xef4444"></div>
                    <div class="swatch" style="background: #10b981; color: #10b981;" data-hex="0x10b981"></div>
                    <div class="swatch" style="background: #f59e0b; color: #f59e0b;" data-hex="0xf59e0b"></div>
                    <div class="swatch" style="background: #d946ef; color: #d946ef;" data-hex="0xd946ef"></div>
                    <div class="swatch" style="background: #ffffff; color: #ffffff;" data-hex="0xffffff"></div>
                </div>
                
                <p class="color-title">ACCESSORIES (30+ OPTIONS)</p>
                <div class="acc-grid" id="acc-container">
                    <!-- Populated by JS -->
                </div>

                <button class="btn" id="btn-create">Host New Race</button>
                <div style="margin: 15px 0; border-top: 1px solid #334155; position: relative;">
                    <span style="position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: rgba(10, 10, 20, 1); padding: 0 10px; font-size: 12px; color: #94a3b8; font-weight: bold;">OR JOIN FRIEND</span>
                </div>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="join-input" placeholder="CODE" maxlength="4" style="margin-bottom: 0;">
                    <button class="btn secondary" id="btn-join" style="margin-bottom: 0;">Join</button>
                </div>
            </div>

            <div id="host-menu">
                <p style="color: #94a3b8; font-weight: bold;">YOUR ROOM CODE:</p>
                <div class="room-code-display" id="display-code">ABCD</div>
                <p style="color: #94a3b8; font-size: 12px;">Share link to invite friends:</p>
                <div class="link-box" id="display-link">https://...</div>
                <button class="btn secondary" id="btn-copy" style="margin-bottom: 20px;">Copy Link</button>
                <br>
                <p style="color: #00f2fe; font-size: 14px; margin-bottom: 10px;">Waiting for players in Chat...</p>
                <button class="btn" id="btn-start">Enter Course</button>
            </div>

            <div id="loading-menu">
                <h2 style="color: #d946ef; letter-spacing: 3px;" id="loading-text">CONNECTING...</h2>
            </div>
        </div>

        <!-- Pre-game Chat Lobby -->
        <div id="chat-lobby-box">
            <h3 style="margin: 0 0 10px 0; color: #8b5cf6;">LOBBY CHAT</h3>
            <div id="chat-messages" class="chat-container">
                <div class="chat-msg" style="color: #94a3b8; font-style: italic;">Welcome to the Lobby!</div>
            </div>
            <div class="chat-input-row">
                <input type="text" id="chat-input" placeholder="Say hi..." style="margin-bottom: 0; border-color: #8b5cf6;">
                <button class="btn" id="btn-send-chat" style="width: auto; margin-bottom: 0; padding: 10px 15px;">Send</button>
            </div>
        </div>
    </div>

    <!-- IN-GAME UI -->
    <div id="ui-container">
        <div id="freeze-overlay"></div>
        <div id="speed-lines"></div>
        <div id="look-hint">🖱️ Click & Drag to look around</div>

        <!-- Top Center: Room Code -->
        <div id="room-code-hud">
            <span>INVITE FRIENDS WITH CODE:</span>
            <div id="hud-code-display" style="letter-spacing: 5px;">ABCD</div>
        </div>

        <!-- Top Left: Status, Stage & Sprint -->
        <div id="top-left-hud" class="hud-panel">
            <div id="stage-indicator">STAGE 1 / 5</div>
            <div id="time-board"><span id="timer">WAITING</span></div>
            <div id="sprint-container">
                <div id="sprint-fill"></div>
                <div id="sprint-text">SPRINT STAMINA</div>
            </div>
            <div id="status-board">Room: <span id="room-display">Local</span> | Racers: <span id="player-count">1</span></div>
        </div>
        
        <!-- Top Right: Controls & Leaderboard -->
        <div id="top-right-hud" class="hud-panel">
            <h3 style="margin: 0 0 10px 0; color: #c4b5fd;">CONTROLS</h3>
            <p><span class="key">W A S D</span> Move</p>
            <p><span class="key">SHIFT</span> Sprint (Boosts Speed/Jump)</p>
            <p><span class="key">SPACE</span> Jump</p>
            <p><span class="key">E</span> Use Item</p>
            <p><span class="key">ENTER</span> Chat</p>
            <p>🖱️ Drag Mouse to Look</p>
            
            <div id="leaderboard-hud">
                <div class="lb-title">LIVE RANKINGS</div>
                <div id="leaderboard-list">
                    <div class="leaderboard-entry" style="color: #64748b;">Calculating...</div>
                </div>
            </div>
        </div>

        <!-- Bottom Left: In-Game Chat -->
        <div id="in-game-chat">
            <div id="ig-chat-messages">
                <div class="chat-msg" style="color: #00f2fe; font-style: italic; text-shadow: 1px 1px 2px #000;">Press ENTER to chat!</div>
            </div>
            <div class="chat-input-row" id="ig-chat-input-container">
                <input type="text" id="ig-chat-input" placeholder="Type message..." style="margin-bottom: 0; background: rgba(0,0,0,0.8);">
            </div>
        </div>

        <!-- Bottom Right: Item Inventory -->
        <div id="item-slot-container">
            <div class="item-key-hint">E</div>
            <div id="item-slot">❓</div>
        </div>

        <!-- Mid Left: Host Admin Panel -->
        <div id="host-panel" class="hud-panel">
            <h3 style="margin: 0 0 10px 0; color: #ef4444; text-align: center;">HOST ADMIN</h3>
            <button class="btn" id="admin-start" style="padding: 8px; font-size: 12px; margin-bottom: 10px;">START RACE</button>
            <button class="btn secondary" id="admin-reset" style="padding: 8px; font-size: 12px; margin-bottom: 0; border-color:#ef4444; color:#ef4444;">RESET EVERYONE</button>
        </div>

        <div id="race-message">GO!</div>
    </div>

    <!-- SCRIPTS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // =========================================================
        // 1. ENGINE & GLOBALS
        // =========================================================
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x030308);
        scene.fog = new THREE.FogExp2(0x030308, 0.0015);

        const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 3000);
        const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: "high-performance" });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        document.getElementById('bg-canvas-container').appendChild(renderer.domElement);

        scene.add(new THREE.AmbientLight(0xffffff, 0.4));
        const mainLight = new THREE.DirectionalLight(0xffffff, 1.2);
        mainLight.position.set(200, 400, 200); mainLight.castShadow = true;
        mainLight.shadow.camera.top = 500; mainLight.shadow.camera.bottom = -500;
        mainLight.shadow.camera.left = -500; mainLight.shadow.camera.right = 500;
        mainLight.shadow.mapSize.width = 2048; mainLight.shadow.mapSize.height = 2048;
        scene.add(mainLight);

        window.gameActive = false; window.isTyping = false; 
        var myName = "RACER"; var myAvatarColor = 0x3b82f6; var myAvatarClass = "classic"; var myAccessoryId = 0;
        var localPlayer = null; var playerGrp = null;
        var isGrounded = false; var velocity = new THREE.Vector3();
        var currentStage = 1; var respawnPoint = new THREE.Vector3(0, 10, 0);
        var camYaw = 0; var camPitch = 0.2; const camDist = 18;

        const ITEMS = { NONE: 0, BOOST: 1, MINE: 2, FREEZE: 3, WARP: 4 };
        const ITEM_EMOJIS = { 0: " ", 1: "🍄", 2: "💣", 3: "❄️", 4: "🚀" };
        var currentItem = ITEMS.NONE;
        var hasBoost = false; var boostTimer = 0;
        var isFrozen = false; var freezeTimer = 0;
        var isStunned = false; var stunTimer = 0;

        var sprintStamina = 100; const MAX_SPRINT = 100; const SPRINT_DRAIN = 1.0; const SPRINT_REGEN = 0.5;

        // Firebase Globals
        var app, auth, db, myId = "", isHost = false, roomCode = "";
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'cyber-obby-v4';
        const remotePlayers = new Map(); 
        
        var raceStarted = false; var raceFinished = false; var startTime = 0; var finishedTimeMs = 0; var leaderboard = [];

        const platforms = []; const itemBoxes = []; const portals = []; const dynamicObjects = []; const hazards = [];

        const GRAVITY = 0.07; const TERMINAL_VELOCITY = -3.5;
        const MOVE_SPEED = 0.8; const SPRINT_SPEED = 1.4;
        const JUMP_FORCE = 1.1; const SPRINT_JUMP = 1.5;
        const PLAYER_RADIUS = 1.2; const PLAYER_HEIGHT = 4.0; 

        // =========================================================
        // 2. MATERIALS
        // =========================================================
        const MATS = {
            black: new THREE.MeshStandardMaterial({ color: 0x111118, roughness: 0.8 }),
            visor: new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0xffffff, emissiveIntensity: 0.5 }),
            droneEye: new THREE.MeshStandardMaterial({ color: 0x00f2fe, emissive: 0x00f2fe }),
            stage1: new THREE.MeshStandardMaterial({ color: 0x1e1b4b, roughness: 0.6, metalness: 0.4 }),
            stage1_neon: new THREE.MeshStandardMaterial({ color: 0x8b5cf6, emissive: 0x8b5cf6, emissiveIntensity: 0.5 }),
            stage2: new THREE.MeshStandardMaterial({ color: 0x064e3b, roughness: 0.9 }),
            stage2_neon: new THREE.MeshStandardMaterial({ color: 0x10b981, emissive: 0x10b981 }),
            stage3: new THREE.MeshStandardMaterial({ color: 0x7c2d12, roughness: 0.7, metalness: 0.8 }),
            stage3_neon: new THREE.MeshStandardMaterial({ color: 0xf97316, emissive: 0xf97316 }),
            stage4: new THREE.MeshStandardMaterial({ color: 0x2e1065, roughness: 0.5, transparent: true, opacity: 0.8 }),
