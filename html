        function addPlatform(x, y, z, w, h, d, matMain, matEdge, type="normal", extra={}) {
            const mesh = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), matMain);
            mesh.position.set(x, y, z); mesh.castShadow = true; mesh.receiveShadow = true;
            const trim = new THREE.Mesh(new THREE.BoxGeometry(w+0.2, h*0.1, d+0.2), matEdge);
            trim.position.y = h/2 - (h*0.05); mesh.add(trim); scene.add(mesh);
            const plat = { mesh, type, x, y, z, w, h, d, minX: x-w/2, maxX: x+w/2, minY: y-h/2, maxY: y+h/2, minZ: z-d/2, maxZ: z+d/2, ...extra };
            if(extra.moveRange) plat.moveOffset = Math.random() * Math.PI * 2;
            platforms.push(plat); return plat;
        }

        function buildItemBox(x, y, z) {
            const inner = new THREE.Mesh(new THREE.BoxGeometry(1.5, 1.5, 1.5), MATS.itemBox);
            const outer = new THREE.Mesh(new THREE.BoxGeometry(2, 2, 2), MATS.itemBox);
            inner.position.set(x, y, z); outer.position.set(x, y, z); scene.add(inner, outer);
            itemBoxes.push({ inner, outer, x, y, z, active: true, respawnTimer: 0 });
        }

        function buildPortal(x, y, z, targetStage, targetPos) {
            const portal = new THREE.Mesh(new THREE.CylinderGeometry(4, 4, 1, 32), MATS.portal);
            portal.rotation.x = Math.PI / 2; portal.position.set(x, y+4, z); scene.add(portal);
            portals.push({ mesh: portal, x, y: y+4, z, targetStage, targetPos });
            const pLight = new THREE.PointLight(0x00f2fe, 2, 40); pLight.position.set(x,y+4,z); scene.add(pLight);
        }

