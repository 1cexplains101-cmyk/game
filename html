                localPlayer.droneItem.visible = currentItem !== ITEMS.NONE;
                if(currentItem === ITEMS.BOOST) localPlayer.droneItem.material.color.setHex(0xffaa00);
                if(currentItem === ITEMS.MINE) localPlayer.droneItem.material.color.setHex(0xff0000);
                if(currentItem === ITEMS.FREEZE) localPlayer.droneItem.material.color.setHex(0x00ffff);
                if(currentItem === ITEMS.WARP) localPlayer.droneItem.material.color.setHex(0xd946ef);
            }
        }

        function useItem() {
            if (currentItem === ITEMS.NONE || isFrozen || isStunned) return;

            if (currentItem === ITEMS.BOOST) {
                hasBoost = true; boostTimer = 4000; showFloatingText("OVERDRIVE!", playerGrp.position, "#ffaa00"); syncEvent('use_boost');
            } else if (currentItem === ITEMS.MINE) {
                const pos = playerGrp.position.clone(); spawnMine(myId, pos); syncEvent('spawn_mine', { x: pos.x, y: pos.y, z: pos.z });
            } else if (currentItem === ITEMS.FREEZE) {
                const pos = playerGrp.position.clone(); pos.y += 2;
                const dir = new THREE.Vector3(0,0,-1).applyQuaternion(playerGrp.quaternion);
                spawnProjectile(myId, pos, dir); syncEvent('spawn_projectile', { x: pos.x, y: pos.y, z: pos.z, dx: dir.x, dz: dir.z });
            } else if (currentItem === ITEMS.WARP) {
                const dir = new THREE.Vector3(0,0,-1).applyQuaternion(playerGrp.quaternion);
                playerGrp.position.add(dir.multiplyScalar(50)); playerGrp.position.y += 10; velocity.set(0,0,0);
                showFloatingText("WARP JUMP!", playerGrp.position, "#d946ef");
