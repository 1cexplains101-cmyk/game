        function checkCollision(pos, plat) {
            if (plat.type === 'blink' && !plat.mesh.visible) return false; 
            const r = PLAYER_RADIUS; const h = PLAYER_HEIGHT;
            return (pos.x + r > plat.minX && pos.x - r < plat.maxX && pos.z + r > plat.minZ && pos.z - r < plat.maxZ && pos.y + h > plat.minY && pos.y < plat.maxY);
        }

        function showFloatingText(text, pos, color) {
            const div = document.createElement('div'); div.className = 'floating-text'; div.innerText = text; div.style.color = color;
            document.body.appendChild(div);
            const vec = pos.clone(); vec.y += 3; vec.project(camera);
            div.style.left = `${(vec.x * .5 + .5) * window.innerWidth}px`; div.style.top = `${(vec.y * -.5 + .5) * window.innerHeight}px`;
            setTimeout(() => div.remove(), 1200);
        }

        var animTime = 0; var menuCamAngle = 0;

        function gameLoop() {
            requestAnimationFrame(gameLoop);
            const time = Date.now();

            if (!window.gameActive) {
                menuCamAngle += 0.002; camera.position.set(Math.sin(menuCamAngle)*40, 20, Math.cos(menuCamAngle)*40 - 20); camera.lookAt(0, 0, -20);
                if(menuAvatar) { menuAvatar.group.rotation.y += 0.01; menuAvatar.droneGrp.position.y = 4.5 + Math.sin(time * 0.005) * 0.3; }
                renderer.render(scene, camera); return;
            }

            if(!playerGrp || !localPlayer) return; 

            if (raceStarted && !raceFinished) { document.getElementById('timer').innerText = formatTime(time - startTime); if(time % 30 === 0) updateLiveRanks(); }
            document.getElementById('stage-indicator').innerText = `STAGE ${currentStage} / 5`;
            
            if (boostTimer > 0) { boostTimer -= 16; if(boostTimer <= 0) hasBoost = false; }
            if (stunTimer > 0) { stunTimer -= 16; if(stunTimer <= 0) isStunned = false; }
            if (freezeTimer > 0) { freezeTimer -= 16; if(freezeTimer <= 0) { isFrozen = false; localPlayer.iceBlock.visible = false; document.getElementById('freeze-overlay').style.display='none'; } }

            const isSprinting = (keys['ShiftLeft'] || keys['ShiftRight']) && sprintStamina > 0 && isGrounded && !window.isTyping;
            if (isSprinting) sprintStamina = Math.max(0, sprintStamina - SPRINT_DRAIN);
            else sprintStamina = Math.min(MAX_SPRINT, sprintStamina + SPRINT_REGEN);
            
            const sf = document.getElementById('sprint-fill');
            if(sf) { sf.style.width = `${(sprintStamina/MAX_SPRINT)*100}%`; sf.style.background = sprintStamina < 15 ? "linear-gradient(90deg, #ff0055, #aa0022)" : "linear-gradient(90deg, #ff0055 0%, #00f2fe 100%)"; }
            const sl = document.getElementById('speed-lines'); if(sl) sl.style.opacity = (hasBoost || isSprinting) ? "1" : "0";

            platforms.forEach(p => {
                if (p.type === 'blink') { p.mesh.visible = Math.floor((time + p.blinkOffset) / p.blinkFreq) % 2 === 0; }
                if (p.moveRange > 0) {
                    const oldX = p.mesh.position.x; p.mesh.position.x = p.origX + Math.sin((time * p.moveSpeed) + p.moveOffset) * p.moveRange;
                    const dx = p.mesh.position.x - oldX; p.minX += dx; p.maxX += dx; p.x = p.mesh.position.x;
                }
            });

            hazards.forEach(h => {
                if(h.type === 'rotlase') {
                    h.pivot.rotation.y += h.speed;
                    if (playerGrp.position.y > h.y - 2 && playerGrp.position.y < h.y + 2) {
                        if (new THREE.Vector2(playerGrp.position.x - h.x, playerGrp.position.z - h.z).length() < h.length) {
                            let aToPlayer = Math.atan2(playerGrp.position.x - h.x, playerGrp.position.z - h.z); if (aToPlayer < 0) aToPlayer += Math.PI*2;
                            let lAngle = h.pivot.rotation.y % (Math.PI*2); if (lAngle < 0) lAngle += Math.PI*2;
                            if (Math.abs(aToPlayer - lAngle) < 0.1 || Math.abs(aToPlayer - (lAngle+Math.PI)%(Math.PI*2)) < 0.1) dieAndRespawn("LASERED!");
                        }
                    }
                }
            });

            itemBoxes.forEach(b => {
                b.inner.rotation.x += 0.02; b.inner.rotation.y += 0.02; b.outer.rotation.x -= 0.01; b.outer.rotation.y -= 0.01;
                if(!b.active && time > b.respawnTimer) { b.active = true; b.inner.visible = true; b.outer.visible = true; }
            });
            portals.forEach(p => p.mesh.rotation.y += 0.05);

            for (let i = dynamicObjects.length - 1; i >= 0; i--) {
                const o = dynamicObjects[i]; if (!o.active) continue;
                if (o.type === 'projectile') {
                    o.mesh.position.add(o.vel); o.life--;
                    if (o.life <= 0) { scene.remove(o.mesh); o.active = false; }
                    else if (o.owner !== myId && playerGrp.position.distanceTo(o.mesh.position) < 3) { applyFreeze(); scene.remove(o.mesh); o.active = false; syncEvent('hit_projectile', { ownerId: o.owner }); }
                } else if (o.type === 'mine') {
                    o.mesh.rotation.y += 0.1;
                    if (o.owner !== myId && playerGrp.position.distanceTo(o.mesh.position) < 2.5 && !isStunned) { applyStun(); scene.remove(o.mesh); o.active = false; syncEvent('hit_mine', { ownerId: o.owner }); }
                }
            }

            if (!isFrozen && !isStunned && !window.isTyping) {
                let speed = hasBoost ? MOVE_SPEED * 1.8 : (isSprinting ? SPRINT_SPEED : MOVE_SPEED);
                
                let moveX = 0; let moveZ = 0;
                if (keys['KeyW']) moveZ -= 1; if (keys['KeyS']) moveZ += 1;
                if (keys['KeyA']) moveX -= 1; if (keys['KeyD']) moveX += 1;
                
                if (moveX !== 0 || moveZ !== 0) {
                    const moveVec = new THREE.Vector3(moveX, 0, moveZ).normalize();
                    moveVec.applyAxisAngle(new THREE.Vector3(0,1,0), camYaw);
                    
                    velocity.x = THREE.MathUtils.lerp(velocity.x, moveVec.x * speed, isGrounded ? 0.6 : 0.3);
                    velocity.z = THREE.MathUtils.lerp(velocity.z, moveVec.z * speed, isGrounded ? 0.6 : 0.3);

                    // Add Math.PI to rotation logic to properly face direction of movement without looking backwards
                    const targetAngle = Math.atan2(velocity.x, velocity.z) + Math.PI;
                    let diff = targetAngle - playerGrp.rotation.y;
                    while(diff < -Math.PI) diff += Math.PI*2; while(diff > Math.PI) diff -= Math.PI*2;
                    playerGrp.rotation.y += diff * 0.4; 
                } else {
                    velocity.x *= isGrounded ? 0.4 : 0.95; velocity.z *= isGrounded ? 0.4 : 0.95;
                }

                if (keys['Space'] && isGrounded) {
                    velocity.y = hasBoost ? JUMP_FORCE * 1.3 : (isSprinting ? SPRINT_JUMP : JUMP_FORCE);
                    isGrounded = false;
                }
            }

            velocity.y -= GRAVITY;
            if (velocity.y < TERMINAL_VELOCITY) velocity.y = TERMINAL_VELOCITY;

            playerGrp.position.x += velocity.x;
            for (let p of platforms) {
                if (checkCollision(playerGrp.position, p)) {
                    if (velocity.x > 0) playerGrp.position.x = p.minX - PLAYER_RADIUS; else if (velocity.x < 0) playerGrp.position.x = p.maxX + PLAYER_RADIUS; 
                    velocity.x = 0;
                }
            }

            playerGrp.position.z += velocity.z;
            if (startBarrier && startBarrier.parent && playerGrp.position.z < -19 && playerGrp.position.z > -21 && Math.abs(playerGrp.position.x) < 20) {
                playerGrp.position.z = -19; velocity.z = 0;
            }
            for (let p of platforms) {
                if (checkCollision(playerGrp.position, p)) {
                    if (velocity.z > 0) playerGrp.position.z = p.minZ - PLAYER_RADIUS; else if (velocity.z < 0) playerGrp.position.z = p.maxZ + PLAYER_RADIUS;
                    velocity.z = 0;
                }
            }

            playerGrp.position.y += velocity.y;
            isGrounded = false; let stoodOn = null;
            for (let p of platforms) {
                if (checkCollision(playerGrp.position, p)) {
                    if (velocity.y < 0) { 
                        playerGrp.position.y = p.maxY; velocity.y = 0; isGrounded = true; stoodOn = p;
                        if (p.moveRange > 0) playerGrp.position.x += Math.cos((time * p.moveSpeed) + p.moveOffset) * p.moveRange * p.moveSpeed;
                    } else if (velocity.y > 0) { 
                        playerGrp.position.y = p.minY - PLAYER_HEIGHT; velocity.y = 0;
                    }
                }
            }

            if (playerGrp.position.y < -40) dieAndRespawn("FELL INTO THE VOID");

            if (stoodOn) {
                if (stoodOn.type === 'lava') dieAndRespawn("INCINERATED!");
                else if (stoodOn.type === 'conveyor' && stoodOn.convZ) playerGrp.position.z += stoodOn.convZ;
                else if (stoodOn.type === 'check') {
                    const checkPos = new THREE.Vector3(stoodOn.mesh.position.x, stoodOn.mesh.position.y + 5, stoodOn.mesh.position.z);
                    if (respawnPoint.distanceTo(checkPos) > 1) { respawnPoint.copy(checkPos); showFloatingText("CHECKPOINT!", playerGrp.position, "#39ff14"); }
                }
                else if (stoodOn.type === 'finish' && raceStarted && !raceFinished) {
                    raceFinished = true; finishedTimeMs = time - startTime;
                    document.getElementById('race-message').innerText = `FINISHED!\n${formatTime(finishedTimeMs)}`;
                    document.getElementById('race-message').style.display = 'block';
                    updateLeaderboard(myId, myName, finishedTimeMs); syncEvent('finish', { time: finishedTimeMs });
                }
            }

            if (!isStunned && !isFrozen) {
                if (currentItem === ITEMS.NONE) {
                    for (let b of itemBoxes) {
                        if (b.active && playerGrp.position.distanceTo(b.inner.position) < 3) {
                            currentItem = rollItem(); updateItemUI();
                            b.active = false; b.inner.visible = false; b.outer.visible = false; b.respawnTimer = time + 5000;
                            showFloatingText("+ ITEM", playerGrp.position, "#fff"); break;
                        }
                    }
                }
                for (let pt of portals) {
                    if (playerGrp.position.distanceTo(pt.mesh.position) < 4) {
                        currentStage = pt.targetStage; respawnPoint.copy(pt.targetPos); playerGrp.position.copy(respawnPoint); velocity.set(0,0,0);
                        camYaw = 0; camPitch = 0.2; showFloatingText(`STAGE ${currentStage}!`, playerGrp.position, "#00ffff"); break;
                    }
                }
            }

            // Animations
            let state = 'idle';
            if (isFrozen) state = 'frozen'; else if (isStunned) state = 'stun'; else if (!isGrounded) state = 'jump'; else if (Math.abs(velocity.x) > 0.05 || Math.abs(velocity.z) > 0.05) state = 'walk';

            if (state === 'walk') {
                animTime += (hasBoost || isSprinting) ? 0.4 : 0.2;
                localPlayer.armL.rotation.x = Math.sin(animTime); localPlayer.armR.rotation.x = -Math.sin(animTime);
                if(localPlayer.legL) { localPlayer.legL.rotation.x = -Math.sin(animTime); localPlayer.legR.rotation.x = Math.sin(animTime); }
            } else if (state === 'jump') {
                localPlayer.armL.rotation.x = Math.PI/2; localPlayer.armR.rotation.x = Math.PI/2; 
                if(localPlayer.legL) { localPlayer.legL.rotation.x = -0.2; localPlayer.legR.rotation.x = 0.2; }
            } else {
                localPlayer.armL.rotation.x = 0; localPlayer.armR.rotation.x = 0;
                if(localPlayer.legL) { localPlayer.legL.rotation.x = 0; localPlayer.legR.rotation.x = 0; }
            }

            localPlayer.droneGrp.position.y = (myAvatarClass==='heavy'?5.0:4.5) + Math.sin(time * 0.005) * 0.3;
            if (currentItem !== ITEMS.NONE) { localPlayer.droneItem.rotation.y += 0.05; localPlayer.droneItem.rotation.x += 0.05; }

            if (time - lastSyncTime > 80) syncLocalPlayer();

            remotePlayers.forEach(p => {
                if(!p.model || !p.model.group) return;
                p.model.group.position.lerp(p.tPos, 0.3); p.model.group.quaternion.slerp(p.tRot, 0.3);
                if (p.state === 'walk') {
                    const w = Math.sin(time * 0.01) * (p.hasBoost ? 1.0 : 0.6);
                    p.model.armL.rotation.x = w; p.model.armR.rotation.x = -w;
                    if(p.model.legL) { p.model.legL.rotation.x = -w; p.model.legR.rotation.x = w; }
                } else if (p.state === 'jump') {
                    p.model.armL.rotation.x = Math.PI/2; p.model.armR.rotation.x = Math.PI/2;
                    if(p.model.legL) { p.model.legL.rotation.x = -0.2; p.model.legR.rotation.x = 0.2; }
                } else {
                    p.model.armL.rotation.x = 0; p.model.armR.rotation.x = 0;
                    if(p.model.legL) { p.model.legL.rotation.x = 0; p.model.legR.rotation.x = 0; }
                }
                p.model.droneGrp.position.y = (p.type==='heavy'?5.0:4.5) + Math.sin(time * 0.005) * 0.3;
                p.model.iceBlock.visible = p.isFrozen; p.model.droneItem.visible = p.item !== ITEMS.NONE;
                if(p.item === ITEMS.BOOST) p.model.droneItem.material.color.setHex(0xffaa00);
                if(p.item === ITEMS.MINE) p.model.droneItem.material.color.setHex(0xff0000);
                if(p.item === ITEMS.FREEZE) p.model.droneItem.material.color.setHex(0x00ffff);
                if(p.item === ITEMS.WARP) p.model.droneItem.material.color.setHex(0xd946ef);
            });

            // 3rd Person Orbital Camera
            const target = playerGrp.position.clone(); target.y += 3; 
            const offsetX = Math.sin(camYaw) * Math.cos(camPitch) * camDist;
            const offsetY = Math.sin(camPitch) * camDist;
            const offsetZ = Math.cos(camYaw) * Math.cos(camPitch) * camDist;

            camera.position.x = THREE.MathUtils.lerp(camera.position.x, target.x + offsetX, 0.3);
            camera.position.y = THREE.MathUtils.lerp(camera.position.y, target.y + offsetY, 0.3);
            camera.position.z = THREE.MathUtils.lerp(camera.position.z, target.z + offsetZ, 0.3);
            camera.lookAt(target);

            renderer.render(scene, camera);
        }

        requestAnimationFrame(gameLoop);

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
