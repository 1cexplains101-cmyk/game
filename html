            ctx.font = 'bold 60px Orbitron, sans-serif'; ctx.fillStyle = '#' + colorHex.toString(16).padStart(6, '0');
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(nameStr, 256, 64);
            const sprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: new THREE.CanvasTexture(canvas), transparent: true }));
            sprite.scale.set(6, 1.5, 1); sprite.position.y = 6.5; return sprite;
        }

        function createAvatar(colorHex, type, nameStr, accId=0) {
            const group = new THREE.Group();
            const matSuit = new THREE.MeshStandardMaterial({ color: colorHex, roughness: 0.4, metalness: 0.2, emissive: colorHex, emissiveIntensity: 0.2 });

            let torsoGeo, headGeo, armGeo, legGeo, headY, armOffset, legOffset;
            if (type === 'heavy') {
                torsoGeo = new THREE.BoxGeometry(2.4, 2.2, 1.2); headGeo = new THREE.BoxGeometry(1.0, 1.0, 1.0);
                armGeo = new THREE.BoxGeometry(0.8, 2.0, 0.8); legGeo = new THREE.BoxGeometry(0.9, 1.4, 0.9);
                armOffset = 1.6; legOffset = 0.7; headY = 3.6;
            } else if (type === 'sleek') {
                torsoGeo = new THREE.BoxGeometry(1.2, 2.6, 0.8); headGeo = new THREE.BoxGeometry(1.0, 1.4, 1.2);
                armGeo = new THREE.BoxGeometry(0.3, 2.4, 0.3); legGeo = new THREE.BoxGeometry(0.4, 1.8, 0.4);
                armOffset = 0.8; legOffset = 0.3; headY = 4.2;
            } else if (type === 'hover') {
                torsoGeo = new THREE.CylinderGeometry(1.0, 0.5, 2.5, 16); headGeo = new THREE.SphereGeometry(0.8, 16, 16);
                armGeo = new THREE.BoxGeometry(0.4, 1.6, 0.4); legGeo = null; 
                armOffset = 1.3; legOffset = 0; headY = 4.0;
            } else { 
                torsoGeo = new THREE.BoxGeometry(1.6, 2.2, 1.0); headGeo = new THREE.BoxGeometry(1.3, 1.3, 1.3);
                armGeo = new THREE.BoxGeometry(0.5, 1.8, 0.5); legGeo = new THREE.BoxGeometry(0.6, 1.4, 0.6);
                armOffset = 1.1; legOffset = 0.5; headY = 3.8;
            }

            const torso = new THREE.Mesh(torsoGeo, MATS.black);
            torso.position.y = type === 'hover' ? 2.5 : 2.0; torso.castShadow = true; group.add(torso);

            const headGrp = new THREE.Group(); headGrp.position.y = headY;
            const head = new THREE.Mesh(headGeo, matSuit); head.castShadow = true; headGrp.add(head);
            const visor = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.3, 1.4), MATS.visor);
            visor.position.set(0, 0.1, -0.1); headGrp.add(visor);
            group.add(headGrp);

            function createLimb(x, y, z, geo, mat) {
                if(!geo) return new THREE.Group();
                const pivot = new THREE.Group(); pivot.position.set(x, y, z);
                const mesh = new THREE.Mesh(geo, mat); mesh.position.y = -geo.parameters.height/2; mesh.castShadow = true;
                pivot.add(mesh); return pivot;
            }

            const armL = createLimb(armOffset, headY - 0.8, 0, armGeo, matSuit);
            const armR = createLimb(-armOffset, headY - 0.8, 0, armGeo, matSuit);
            const legL = createLimb(legOffset, 1.0, 0, legGeo, MATS.black);
            const legR = createLimb(-legOffset, 1.0, 0, legGeo, MATS.black);

            if (type === 'hover') {
                const thruster = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.8, 0.5, 16), matSuit);
                thruster.position.y = 1.0; group.add(thruster);
            } else {
                const bootL = new THREE.Mesh(new THREE.BoxGeometry(legGeo.parameters.width+0.1, 0.5, legGeo.parameters.depth+0.2), matSuit); bootL.position.set(0,-legGeo.parameters.height/2 + 0.25,-0.1); legL.children[0].add(bootL);
                const bootR = new THREE.Mesh(new THREE.BoxGeometry(legGeo.parameters.width+0.1, 0.5, legGeo.parameters.depth+0.2), matSuit); bootR.position.set(0,-legGeo.parameters.height/2 + 0.25,-0.1); legR.children[0].add(bootR);
            }
            group.add(armL, armR, legL, legR);

            const nametag = createNametag(nameStr, colorHex);
            group.add(nametag);

            const droneGrp = new THREE.Group(); droneGrp.position.set(-1.8, headY + 1.0, 1.2);
            const droneBody = new THREE.Mesh(new THREE.SphereGeometry(0.4, 16, 16), matSuit);
            const droneEye = new THREE.Mesh(new THREE.SphereGeometry(0.2, 16, 16), MATS.droneEye); droneEye.position.z = -0.3;
            const droneItem = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.5, 0.5), new THREE.MeshBasicMaterial({color:0xffffff, wireframe:true}));
            droneItem.position.y = 0.8; droneItem.visible = false;
            droneGrp.add(droneBody, droneEye, droneItem); group.add(droneGrp);

            const iceBlock = new THREE.Mesh(new THREE.BoxGeometry(4.5, 6.5, 4.5), MATS.iceCube);
            iceBlock.position.y = 2.5; iceBlock.visible = false; group.add(iceBlock);

            const accData = ACC_DATA.find(a => a.id === accId);
            if(accData && accData.slot !== 'none') {
                const accMesh = buildAccessory(accId);
                if(accData.slot === 'head' || accData.slot === 'face') {
                    if(accData.slot==='head') accMesh.position.y = headGeo.parameters.height/2;
                    headGrp.add(accMesh);
                } else if(accData.slot === 'back') {
                    accMesh.position.set(0, torso.position.y, torsoGeo.parameters.depth/2);
                    group.add(accMesh);
                }
            }

            return { group, armL, armR, legL, legR, headGrp, droneGrp, droneItem, iceBlock, nametag, color: colorHex, type, accId };
        }

