            const pivot = new THREE.Group(); pivot.position.set(x,y,z);
            const laser = new THREE.Mesh(new THREE.CylinderGeometry(0.5, 0.5, length, 16), MATS.laser);
            laser.rotation.z = Math.PI/2; laser.position.x = length/2; pivot.add(laser); scene.add(pivot);
            hazards.push({ pivot, laser, type: 'rotlase', length, speed, x,y,z });
        }

